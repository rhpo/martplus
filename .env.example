# Supabase — database + storage, all via @supabase/supabase-js (server-side, service role)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=...   # Project Settings → API → service_role secret (server-only, never expose)
SUPABASE_STORAGE_BUCKET=product-images   # create a PUBLIC bucket with this name

# email (Resend)
MAIL_DRIVER=resend
RESEND_API_KEY=...
EMAIL_FROM=MART+ <commandes@martplusdz.com>

# marty assistant — pluggable AI layer (server-side only, key never reaches the client).
# Default provider: Groq (free, fast, doesn't train on your data, generous limits).
# Get a key at https://console.groq.com → API Keys → Create API Key.
AI_PROVIDER=groq                 # groq | openrouter | openai | gemini | mistral | cerebras
AI_API_KEY=...                   # the chosen provider's API key
# Optional overrides (each provider has a sensible default model/base URL):
# AI_MODEL=llama-3.3-70b-versatile
# AI_BASE_URL=https://api.groq.com/openai/v1
# PUBLIC_SITE_URL=https://martplusdz.com   # sent as attribution header (OpenRouter)

# admin + session
ADMIN_PASSWORD=changeme
SESSION_SECRET=replace-with-long-random-string

# contact + delivery
WHATSAPP_NUMBER=2136XXXXXXXX        # business WhatsApp, international digits, no '+'
# STORE_LOCATION and DELIVERY (base 300 / +30 per km / cap 700 / free >= 15000) live in src/lib/config.ts
