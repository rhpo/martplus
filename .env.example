# database (stays sqlite for now; postgres later by swapping the factory)
DB_DRIVER=sqlite
DATABASE_PATH=./data/mart.db

# storage (Amazon S3, now)
STORAGE_DRIVER=s3
AWS_REGION=eu-west-3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET=mart-plus-uploads
S3_PUBLIC_BASE_URL=https://mart-plus-uploads.s3.eu-west-3.amazonaws.com  # or CloudFront; omit if using presigned URLs

# email (Resend)
MAIL_DRIVER=resend
RESEND_API_KEY=...
EMAIL_FROM=MART+ <commandes@martplusdz.com>

# marty assistant (OpenRouter - server-side only, key never reaches the client)
OPENROUTER_API_KEY=...
OPENROUTER_MODEL=openai/gpt-4o-mini

# admin + session
ADMIN_PASSWORD=changeme
SESSION_SECRET=replace-with-long-random-string

# contact + delivery
WHATSAPP_NUMBER=2136XXXXXXXX        # business WhatsApp, international digits, no '+'
# STORE_LOCATION and DELIVERY (base 300 / +30 per km / cap 700 / free >= 15000) live in src/lib/config.ts
